# Secrets (server-side only — set these in Railway per environment, never ship to the client)
DEEPGRAM_API_KEY=your-deepgram-api-key-here
DEEPSEEK_API_KEY=your-deepseek-api-key-here
MINIMAX_API_KEY=your-minimax-api-key-here
CONVEX_BACKEND_KEY=your-convex-backend-key-here

# Convex deployment (public URL; convex_client derives the .site HTTP-actions URL).
# dev:  https://qualified-cuttlefish-550.convex.cloud
# prod: https://unique-jaguar-230.convex.cloud
VITE_CONVEX_URL=https://your-deployment.convex.cloud

# Clerk JWKS endpoint (public) — only used for the token/dashboard auth path.
CLERK_JWKS_URL=https://your-clerk-issuer/.well-known/jwks.json

# Deployment env: "dev" | "live"
APP_ENV=dev

# CORS + WebSocket Origin allowlist (comma-separated). The desktop Tauri WebView
# origin is "http://tauri.localhost" (Windows) / "tauri://localhost" (macOS);
# dev uses "http://localhost:5173". Empty falls back to the dev origin.
ALLOWED_ORIGINS=http://tauri.localhost,tauri://localhost,http://localhost:5173

# Reject WS handshakes whose Origin is present but not allowlisted. Start False
# (log-only) until you confirm the real Tauri origin from the logs, then flip to true.
ENFORCE_WS_ORIGIN=false

# Local dev only (Railway injects PORT automatically)
PORT=8000
