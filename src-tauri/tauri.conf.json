{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "interview-responder",
  "version": "0.1.3",
  "identifier": "com.interviewresponder.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Interview Copilot",
        "width": 730,
        "height": 730,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "alwaysOnTop": true,
        "visible": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEI2NkYyNDZFNjFEMjNENDYKUldSR1BkSmhiaVJ2dGxmZ0hpR3BSUzdQbk1qOUxPUEYxL1puL1NoRDhSTjZPYm9Hd0prbVVwQVMK",
      "endpoints": [
        "https://updates.wininterview.xyz/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
