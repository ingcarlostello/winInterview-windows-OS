{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "convex": {
      "type": "local",
      "command": ["npx", "-y", "convex@latest", "mcp", "start", "--project-dir", "/Users/carlos/Desktop/interview_responder"],
      "enabled": true
    },
    "clerk": {
      "type": "remote",
      "url": "https://mcp.clerk.com/mcp",
      "enabled": true
    },
    "paddle-sandbox": {
      "type": "remote",
      "url": "https://sandbox-mcp.paddle.com/mcp",
      "enabled": true,
      "headers": {
        "Authorization": "Bearer {env:PADDLE_SANDBOX_API_KEY}"
      }
    },
    "paddle-live": {
      "type": "remote",
      "url": "https://mcp.paddle.com/mcp",
      "enabled": true,
      "headers": {
        "Authorization": "Bearer {env:PADDLE_LIVE_API_KEY}"
      }
    }
  }
}