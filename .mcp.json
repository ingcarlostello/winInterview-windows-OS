{
  "mcpServers": {
    "convex": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "convex@latest",
        "mcp",
        "start",
        "--project-dir",
        "C:/Users/react/OneDrive/Desktop/win-interview/winInterview-windows-OS"
      ],
      "env": {}
    },
    "clerk": {
      "type": "http",
      "url": "https://mcp.clerk.com/mcp"
    },
    "paddle-live": {
      "type": "http",
      "url": "https://mcp.paddle.com/mcp",
      "headers": {
        "Authorization": "Bearer ${PADDLE_LIVE_API_KEY}"
      }
    },
    "paddle-sandbox": {
      "type": "http",
      "url": "https://sandbox-mcp.paddle.com/mcp",
      "headers": {
        "Authorization": "Bearer PADDLE_SANDBOX_API_KEY_HERE"
      }
    },
    "railway": {
      "type": "http",
      "url": "https://mcp.railway.com"
    },
    "hostinger-hosting": {
      "type": "stdio",
      "command": "npx.cmd",
      "args": ["--package=hostinger-api-mcp@latest", "hostinger-hosting-mcp"],
      "env": { "HOSTINGER_API_TOKEN": "${HOSTINGER_API_TOKEN}" }
    },
    "hostinger-domains": {
      "type": "stdio",
      "command": "npx.cmd",
      "args": ["--package=hostinger-api-mcp@latest", "hostinger-domains-mcp"],
      "env": { "HOSTINGER_API_TOKEN": "${HOSTINGER_API_TOKEN}" }
    },
    "hostinger-dns": {
      "type": "stdio",
      "command": "npx.cmd",
      "args": ["--package=hostinger-api-mcp@latest", "hostinger-dns-mcp"],
      "env": { "HOSTINGER_API_TOKEN": "${HOSTINGER_API_TOKEN}" }
    },
    "hostinger-billing": {
      "type": "stdio",
      "command": "npx.cmd",
      "args": ["--package=hostinger-api-mcp@latest", "hostinger-billing-mcp"],
      "env": { "HOSTINGER_API_TOKEN": "${HOSTINGER_API_TOKEN}" }
    },
    "hostinger-reach": {
      "type": "stdio",
      "command": "npx.cmd",
      "args": ["--package=hostinger-api-mcp@latest", "hostinger-reach-mcp"],
      "env": { "HOSTINGER_API_TOKEN": "${HOSTINGER_API_TOKEN}" }
    }
  }
}